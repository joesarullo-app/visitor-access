{
  "extends": "../tsconfig.json",
  "include": ["./**/*", "../server/**/*", "../shared/**/*"],
  "exclude": [
    "../node_modules",
    "../dist",
    "../server/vite.ts",
    "../server/static.ts",
    "../server/index.ts",
    "../vite.config.ts",
    "../client/**/*",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "module": "ES2022",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": ["node"],
    "jsx": "react-jsx",
    "incremental": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
