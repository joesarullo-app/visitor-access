{
  "extends": "../tsconfig.json",
  "include": ["./**/*", "../server/**/*", "../shared/**/*"],
  "exclude": ["../node_modules", "../dist"],
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": ["node"],
    "jsx": "react-jsx",
    "incremental": false
  }
}
