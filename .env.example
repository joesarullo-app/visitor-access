# Supabase project URL, e.g. https://atlnyfznamlgjksehvcp.supabase.co
SUPABASE_URL=

# Public anon key for the Supabase project (safe to expose in dev,
# but for this deployment all DB access is server-side).
SUPABASE_ANON_KEY=

# Optional: service role key. If set, the server uses this instead of the
# anon key so it can bypass Row Level Security. NEVER expose this to the
# browser — it must only ever be configured as a Vercel server env var.
# SUPABASE_SERVICE_ROLE_KEY=

# Port for local dev server (optional, defaults to 5000).
# PORT=5000
